{
  "name": "@databolsa/cli",
  "version": "1.0.2",
  "license": "Apache-2.0",
  "type": "module",
  "description": "CLI para a Serving API pública do DataBolsa, com um comando por operação OpenAPI.",
  "bin": {
    "databolsa": "dist/index.js"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --target node --outfile dist/index.js && sed -i '1s|^#!.*|#!/usr/bin/env node|' dist/index.js",
    "prepack": "bun run build"
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": "Rodrigo Klosowski",
  "homepage": "https://github.com/databolsahq/databolsa/tree/main/packages/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/databolsahq/databolsa.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/databolsahq/databolsa/issues"
  },
  "keywords": [
    "databolsa",
    "cli",
    "b3",
    "bovespa",
    "ações",
    "fii",
    "finance",
    "openapi"
  ]
}
