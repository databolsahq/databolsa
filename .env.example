# Copy to .env and adjust. .env is gitignored; this file is tracked.

# --- Local serving DB (the `db` service: TimescaleDB + pgvector) ---
POSTGRES_USER=databolsa
POSTGRES_PASSWORD=databolsa_dev
POSTGRES_DB=databolsa
DB_PORT=5433
# The API reads this (matches the values above):
DATABASE_URL=postgresql://databolsa:databolsa_dev@localhost:5433/databolsa

# --- Serving API (packages/api) ---
# Port the Hono API listens on (default 8080). Override if 8080 is taken locally.
PORT=8080
# Public origin of the API — used in the OpenAPI `servers` URL and as the base of the
# RFC 9457 problem `type` URIs. No trailing slash.
PUBLIC_API_URL=https://api.databolsa.com
# License name surfaced in generated API metadata.
DATABOLSA_CORE_LICENSE=Apache-2.0
# Optional bearer API keys (comma-separated). Set to require `Authorization: Bearer <key>`
# on /v1/* (except /health); leave empty for an open self-host instance.
DATABOLSA_API_KEYS=
# Gateway-trust mode: shared secret proving a request came through a trusted gateway. When set,
# a request with a matching `X-DataBolsa-Gateway` header is trusted and its forwarded
# principal adopted — the core never stores user data. Unset (self-host) → the core uses
# DATABOLSA_API_KEYS above (or runs open).
INTERNAL_GATEWAY_SECRET=

# --- Cache (Redis) ---
# Read-through response cache for the API. Unset REDIS_URL (or CACHE_ENABLED=false) and
# caching is OFF — the API serves straight from Postgres. `docker compose up -d redis`
# provides a disposable instance on REDIS_PORT.
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380
CACHE_ENABLED=true
CACHE_TTL_DEFAULT=21600

# --- Scheduler ---
# Run the scheduler as your host user so files written into ./data stay yours.
# Find them with:  id -u   /   id -g
DOCKER_UID=1000
DOCKER_GID=1000
# Optional: enables the FRED connector (free key at fred.stlouisfed.org).
# Leave empty and FRED is skipped silently.
FRED_API_KEY=
