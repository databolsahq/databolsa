# Copy to .env and adjust. .env is gitignored; this file is tracked.
#
# These packages (@databolsa/sdk, @databolsa/cli, @databolsa/mcp) are clients of
# the DataBolsa API — get an API key at https://databolsa.com and set it below.

# Base URL of the DataBolsa API (override only for a different environment).
DATABOLSA_API_URL=https://api.databolsa.com
# Bearer API key used by the SDK, CLI and MCP server.
DATABOLSA_API_KEY=
